        {
          "title": "Statistiche settimanali",
          "url": "/admin/weekly",
          "icon": "CalendarRange"
        },
        {
          "title": "Statistiche mensili",
          "url": "/admin/monthly",
          "icon": "Calendar"
        },
        {
          "title": "Compiti dell'intelligenza artificiale",
