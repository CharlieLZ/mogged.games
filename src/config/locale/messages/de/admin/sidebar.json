          "icon": "Home",
          "target": "_leer"
        },
        {
          "title": "GitHub",
          "url": "https://github.com/CharlieLZ/mogged.games",
          "icon": "Github",
          "target": "_leer"
        },
        {
          "title": "E-Mail",
          "url": "mailto:{{support_email}}",
          "icon": "Mail",
          "target": "_leer"
        }
      ]
    },
    "show_theme": true,
